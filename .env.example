# Pick one notification method. ServerChan is convenient for WeChat.
SERVERCHAN_SENDKEY=
SERVERCHAN_BASE_URL=https://sctapi.ftqq.com
WECOM_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=

# Config-based runner.
CONFIG_FILE=config.yaml

# Legacy Twitter/X script options.
SOURCE_MODE=rss
X_USERNAME=example_user
X_BEARER_TOKEN=
RSS_FEED_URLS=https://nitter.net/{username}/rss,https://xcancel.com/{username}/rss,https://rss.xcancel.com/{username}/rss,https://twiiit.com/{username}/rss,https://rsshub.app/twitter/user/{username}
STATE_FILE=.state/x-watch.json

# Legacy Damai script options.
DAMAI_ITEM_ID=replace_with_damai_item_id
DAMAI_TARGET_TEXT=replace_with_target_ticket_tier
DAMAI_TARGET_DATES=replace_with_target_dates
DAMAI_STATE_FILE=.state/damai-watch.json

# Legacy Docker loop intervals. The config-based Docker runner uses per-monitor intervals in config.yaml.
ENABLE_X_WATCH=1
ENABLE_DAMAI_WATCH=1
X_INTERVAL_SECONDS=30
DAMAI_INTERVAL_SECONDS=15
